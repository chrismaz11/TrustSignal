{
  "name": "trustsignal-verify-artifact",
  "version": "0.1.0",
  "description": "GitHub Action for verifying build artifacts with TrustSignal and capturing signed verification receipts.",
  "main": "dist/index.js",
  "type": "commonjs",
  "files": [
    "action.yml",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "mkdir -p dist && cp src/index.js dist/index.js",
    "package": "npm run build",
    "check": "node --check src/index.js && node --check dist/index.js",
    "test:local": "node scripts/test-local.js",
    "validate:local": "npm run check && npm run test:local"
  },
  "keywords": [
    "github-action",
    "trustsignal",
    "verification",
    "devsecops",
    "ci-cd",
    "supply-chain",
    "artifact",
    "provenance",
    "compliance"
  ],
  "author": "TrustSignal",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
